-- IntersectMBO/ouroboros-consensus pinned at the
-- release-ouroboros-consensus-0.27.0.0 tag, contemporaneous with
-- cardano-node 10.5.3 (the version Arnaud's testnet fixture is
-- configured for). Provides db-synthesizer and db-analyser exes in
-- the ouroboros-consensus-cardano package; --store-ledger SLOT
-- verified present in this release.
--
-- Constitution Principle III: --sha256 is in nix32 format (NOT SRI).
source-repository-package
  type: git
  location: https://github.com/IntersectMBO/ouroboros-consensus
  tag: 8e3afe103e49c0b1ba66ce0ece5a24dc87e34e26
  --sha256: 15jh9nzp0d9fbdxvwy6k27zzqch6xq08nh1d3xylgd5fkz3ws5vb
  subdir:
    ouroboros-consensus
    ouroboros-consensus-cardano
